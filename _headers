/*
  # Strict Transport Security — force HTTPS for 1 year, include subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent clickjacking — PHL CRM should never be embedded in an iframe
  X-Frame-Options: DENY

  # Prevent MIME type sniffing attacks
  X-Content-Type-Options: nosniff

  # Control referrer information sent to external sites
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features not needed by PHL CRM
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=(self)

  # Content Security Policy
  # - default-src: deny everything not explicitly allowed
  # - script-src: only our own scripts + Stripe (required for Payment Element)
  # - style-src: our styles + inline styles (needed by some React component libs)
  # - connect-src: Supabase API, Supabase Auth, Supabase Realtime, Stripe API, Google Maps
  # - img-src: our images + Supabase Storage + data URIs (avatars) + Google Maps tiles
  # - frame-src: Stripe requires iframe for Payment Element
  # - worker-src: service worker for PWA offline support
  Content-Security-Policy: default-src 'none'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://maps.googleapis.com https://router.project-osrm.org; img-src 'self' data: blob: https://*.supabase.co https://maps.gstatic.com https://maps.googleapis.com; frame-src https://js.stripe.com https://hooks.stripe.com; worker-src 'self' blob:; manifest-src 'self'; form-action 'self'; base-uri 'self'

  # Cross-Origin policies — prevent data leakage via cross-origin requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin


# ============================================================
# Customer Portal — relaxed frame policy for Stripe Payment Element
# ============================================================
/portal/*
  Content-Security-Policy: default-src 'none'; script-src 'self' https://js.stripe.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://maps.googleapis.com; img-src 'self' data: blob: https://*.supabase.co; frame-src https://js.stripe.com https://hooks.stripe.com; worker-src 'self' blob:; manifest-src 'self'; form-action 'self'; base-uri 'self'
  # Portal may be embedded in a customer-facing iframe in future — keep SAMEORIGIN here
  X-Frame-Options: SAMEORIGIN


# ============================================================
# Static assets — aggressive caching, immutable
# ============================================================
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin


# ============================================================
# Service Worker — must not be cached, always fresh
# ============================================================
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /


# ============================================================
# PWA Manifest
# ============================================================
/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: no-cache


# ============================================================
# Estimate approval endpoint — public, unauthenticated
# Token-based access only, no auth cookies
# ============================================================
/portal/approve/*
  X-Frame-Options: DENY
  Cache-Control: no-store, no-cache, must-revalidate
